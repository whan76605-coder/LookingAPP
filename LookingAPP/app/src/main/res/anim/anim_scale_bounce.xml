<?xml version="1.0" encoding="utf-8"?>
<set xmlns:android="http://schemas.android.com/apk/res/android">
    <scale android:fromXScale="1.0" android:toXScale="1.35"
        android:fromYScale="1.0" android:toYScale="1.35"
        android:pivotX="50%" android:pivotY="50%"
        android:duration="150" android:fillAfter="false"/>
    <scale android:fromXScale="1.35" android:toXScale="1.0"
        android:fromYScale="1.35" android:toYScale="1.0"
        android:pivotX="50%" android:pivotY="50%"
        android:startOffset="150" android:duration="120"
        android:interpolator="@android:interpolator/overshoot"/>
</set>
