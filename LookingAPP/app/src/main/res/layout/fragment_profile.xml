<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 顶部蓝紫渐变区 -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_profile_header">

            <!-- 设置按钮 -->
            <ImageView
                android:id="@+id/iv_settings"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="top|end"
                android:layout_margin="16dp"
                android:src="@drawable/ic_settings"
                android:tint="@color/white" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingTop="48dp">

                <!-- 头像 + 信息 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="@dimen/avatar_large"
                        android:layout_height="@dimen/avatar_large"
                        android:src="@drawable/ic_default_avatar"
                        app:civ_border_width="2dp"
                        app:civ_border_color="@color/white" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:id="@+id/tv_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="小熊旅行日记"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white" />

                        <TextView
                            android:id="@+id/tv_bio"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="热爱生活，热爱旅行"
                            android:textSize="13sp"
                            android:textColor="#CCffffff" />
                    </LinearLayout>
                </LinearLayout>

                <!-- 数据统计 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="16dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_follow_count" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="128"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="关注" android:textSize="12sp" android:textColor="#CCffffff"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_fans_count" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="2356"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="粉丝" android:textSize="12sp" android:textColor="#CCffffff"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                        <TextView android:id="@+id/tv_like_count" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="5687"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/white"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="获赞" android:textSize="12sp" android:textColor="#CCffffff"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- 按钮 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="14dp">

                    <TextView android:id="@+id/tv_edit_profile"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="编辑资料"
                        android:textSize="13sp" android:textColor="@color/primary_purple"
                        android:background="@drawable/bg_btn_outline_white"
                        android:layout_marginEnd="8dp"/>

                    <TextView android:id="@+id/tv_my_main"
                        android:layout_width="0dp" android:layout_height="36dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="我的主页"
                        android:textSize="13sp" android:textColor="@color/primary_purple"
                        android:background="@drawable/bg_btn_outline_white"/>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>

        <!-- 我的服务 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/bg_card"
            android:layout_marginTop="8dp"
            android:paddingLeft="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="我的服务" android:textSize="15sp" android:textStyle="bold"
                android:textColor="@color/text_primary" android:paddingTop="14dp" android:paddingBottom="10dp"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal">
                <LinearLayout android:id="@+id/item_collect" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_star_outline" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="我的收藏" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/item_history" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_history" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="浏览历史" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/item_publish" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_add" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="我的发布" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/item_draft" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <FrameLayout
                        android:layout_width="36dp"
                        android:layout_height="36dp">
                        <ImageView android:layout_width="36dp" android:layout_height="36dp"
                            android:src="@drawable/ic_draft" android:tint="@color/primary_purple"/>
                        <TextView
                            android:id="@+id/tv_draft_badge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:gravity="center"
                            android:textSize="9sp"
                            android:textColor="@color/white"
                            android:background="@drawable/bg_draft_badge"
                            android:visibility="gone" />
                    </FrameLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="草稿箱" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginTop="4dp">
                <LinearLayout android:id="@+id/item_like" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_heart_outline" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="我的点赞" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/item_night" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_night" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="夜间模式" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/item_settings" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_settings" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="设置" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
                <LinearLayout android:id="@+id/item_help" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:gravity="center" android:orientation="vertical" android:padding="8dp">
                    <ImageView android:layout_width="36dp" android:layout_height="36dp"
                        android:src="@drawable/ic_help" android:tint="@color/primary_purple"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="帮助与反馈" android:textSize="11sp" android:textColor="@color/text_secondary"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- 内容 TabLayout + RecyclerView -->
        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_layout"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:background="@color/bg_card"
            app:tabGravity="fill"
            app:tabMode="fixed"
            app:tabIndicatorColor="@color/primary_purple"
            app:tabSelectedTextColor="@color/primary_purple"
            app:tabTextColor="@color/text_secondary" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:padding="8dp"
            android:clipToPadding="false" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
