<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_main">

    <!-- 标题栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:gravity="center_vertical"
        android:paddingLeft="4dp"
        android:background="@color/bg_card"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:padding="10dp"
            android:src="@drawable/ic_back"
            android:tint="@color/text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="设置"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <View android:layout_width="44dp" android:layout_height="44dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 账号与安全 -->
            <LinearLayout
                android:id="@+id/ll_account_security"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card" android:layout_marginTop="8dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="账号与安全"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right" android:tint="@color/text_hint"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginLeft="16dp"/>

            <!-- 通知设置 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="消息通知"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <Switch android:id="@+id/sw_notification" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:thumbTint="@color/primary_purple"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginLeft="16dp"/>

            <!-- 夜间模式 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="夜间模式"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <Switch android:id="@+id/sw_dark_mode" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:thumbTint="@color/primary_purple"/>
            </LinearLayout>

            <!-- 通用设置 -->
            <LinearLayout
                android:id="@+id/ll_general_settings"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card" android:layout_marginTop="8dp"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="通用设置"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right" android:tint="@color/text_hint"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginLeft="16dp"/>

            <!-- 清除缓存 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="清除缓存"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/tv_clear_cache"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="12.6MB" android:textSize="13sp" android:textColor="@color/text_hint"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right" android:tint="@color/text_hint"
                    android:layout_marginStart="6dp"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginLeft="16dp"/>

            <!-- 隐私设置 -->
            <LinearLayout
                android:id="@+id/ll_privacy_settings"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card"
                android:clickable="true" android:focusable="true">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="隐私设置"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right" android:tint="@color/text_hint"/>
            </LinearLayout>

            <!-- 关于 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card" android:layout_marginTop="8dp">
                <TextView android:id="@+id/tv_about" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="关于我们" android:textSize="15sp" android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right" android:tint="@color/text_hint"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginLeft="16dp"/>

            <!-- 隐私政策 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card">
                <TextView android:id="@+id/tv_privacy" android:layout_width="0dp"
                    android:layout_height="wrap_content" android:layout_weight="1"
                    android:text="隐私政策" android:textSize="15sp" android:textColor="@color/text_primary"/>
                <ImageView android:layout_width="18dp" android:layout_height="18dp"
                    android:src="@drawable/ic_arrow_right" android:tint="@color/text_hint"/>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp"
                android:background="@color/divider" android:layout_marginLeft="16dp"/>

            <!-- 版本 -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="52dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:paddingLeft="16dp" android:paddingRight="16dp"
                android:background="@color/bg_card">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="当前版本"
                    android:textSize="15sp" android:textColor="@color/text_primary"/>
                <TextView android:id="@+id/tv_version" android:layout_width="wrap_content"
                    android:layout_height="wrap_content" android:text="V1.0.0"
                    android:textSize="13sp" android:textColor="@color/text_hint"/>
            </LinearLayout>

            <!-- 退出登录 -->
            <TextView
                android:id="@+id/tv_logout"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center"
                android:layout_marginTop="16dp"
                android:layout_marginLeft="16dp"
                android:layout_marginRight="16dp"
                android:background="@drawable/bg_btn_outline_red"
                android:text="退出登录"
                android:textSize="16sp"
                android:textColor="#FF3B30" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
